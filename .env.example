# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# Supabase → Dashboard → Connect → **Session pooler** (port 5432, user `postgres.<project-ref>`).
# Do NOT use Transaction pooler (port 6543) for Prisma migrations — it will hang or fail.
# If the dashboard string omits it, append: ?sslmode=require&connect_timeout=30
# Direct host `db.<ref>.supabase.co` works only if your network has working IPv6; otherwise use session pooler.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@<session-pooler-host>:5432/postgres?sslmode=require&connect_timeout=30"

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

PAYSTACK_SECRET_KEY=your_paystack_secret_key
NEXT_PUBLIC_SITE_URL=your_site_url
# Runtime (no rebuild needed on change). Falls back to NEXT_PUBLIC_WHATSAPP_NUMBER if unset.
WHATSAPP_NUMBER=your_whatsapp_number
NEXT_PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number

RESEND_API_KEY=your_resend_api_key
ADMIN_ALERT_EMAIL=your_admin_alert_email
# Legacy fallback if EMAIL_FROM_ALERTS is unset
ADMIN_ALERT_FROM=Lofty Xphere Homes <alerts@loftyxpherehomes.com>

# Transactional From identities (verified domain in Resend)
EMAIL_FROM_BOOKINGS=Lofty Xphere Homes <bookings@loftyxpherehomes.com>
EMAIL_FROM_ALERTS=Lofty Xphere Homes <alerts@loftyxpherehomes.com>
EMAIL_FROM_CONTACT=Lofty Xphere Homes <website@loftyxpherehomes.com>
EMAIL_REPLY_TO=hello@loftyxpherehomes.com

# Contact form: team inbox for new submissions (optional but recommended)
CONTACT_NOTIFY_EMAIL=ops@loftyxpherehomes.com

# --- Admin dashboard + ops ---
# Protect /api/internal/booking-jobs/process (Bearer or x-booking-jobs-secret)
BOOKING_JOBS_SECRET=your_internal_jobs_secret
# Used by production cron providers such as Vercel Cron. Can match BOOKING_JOBS_SECRET.
CRON_SECRET=your_internal_jobs_secret
# Optional override for `npm run process-booking-jobs`; defaults to NEXT_PUBLIC_SITE_URL or localhost.
BOOKING_JOBS_URL=http://localhost:3000

# Google Sheets integration (server-only)
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_spreadsheet_id
# Path to Google service account JSON file on the server
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# Invoice PDF generation (server-only)
# Optional: provide Chrome executable path if channel:chrome is unavailable
CHROME_EXECUTABLE_PATH=/path/to/chrome
INVOICES_DIR=private/invoices

# --- Apartment images (Supabase Storage + Sharp pipeline) ---
# Server-only: required for storage uploads and admin auth operations
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Public bucket for optimized WebP variants (created automatically if missing)
APARTMENT_IMAGES_BUCKET=ApartmentImages
# Max upload size per file in megabytes (default: 10)
APARTMENT_IMAGE_MAX_MB=10
# Max apartment tour video upload in megabytes (default: 50)
APARTMENT_VIDEO_MAX_MB=50
# Supabase per-file plan cap — 50 on Free, up to 500000 on Pro (default: 50)
# SUPABASE_STORAGE_MAX_FILE_MB=50

# Max hero video upload in megabytes (default: 80). Clip length in seconds (default: 60).
HERO_VIDEO_MAX_MB=80
# HERO_VIDEO_MAX_SECONDS=60

# Apartment tour video max length in seconds (default: 100)
# APARTMENT_VIDEO_MAX_SECONDS=100

# Temporary local admin tool: compress large videos before upload (set true in dev only)
# ENABLE_VIDEO_COMPRESS_TOOL=true
# VIDEO_COMPRESS_TOOL_MAX_INPUT_MB=300
# VIDEO_COMPRESS_TOOL_MAX_DURATION_SEC=100
# Optional fixed output size in MB (default: auto by clip length — ~4 MB hero, ~10 MB tour)
# VIDEO_COMPRESS_TOOL_TARGET_MB=8

# --- Analytics ---
# Google Analytics 4 measurement ID (public, inlined at build time)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Google Ads tag ID for remarketing + conversion events (`AW-…` from Ads → Tools → Google tag)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXXX
# Paid ads landing page: /book (defaults to next 2 nights; pass dates & UTM in the ad URL)
# Example: /book?utm_source=google&utm_campaign=brand&checkIn=2026-07-04&checkOut=2026-07-06&guests=2
# Cookie consent banner: off (no popup, full analytics + ads) | eea (EU/UK only) | always (everyone)
NEXT_PUBLIC_COOKIE_CONSENT_MODE=off
# Staff opt-out: server-only secret for `/?lxh_internal=SECRET` (excludes that browser from GA for 1 year)
ANALYTICS_INTERNAL_OPTOUT_SECRET=your-long-random-secret
