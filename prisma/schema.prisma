// Prisma schema for LoftyXphereHomes
// Database: Supabase (PostgreSQL). Set DIRECT_URL in .env (see prisma.config.ts and .env.example).

generator client {
  provider = "prisma-client"
  output = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Booking (created when Paystack payment succeeds) ---

model Booking {
  id           String   @id @default(cuid())
  reference    String   @unique // Paystack transaction reference (e.g. lxh_meridian-suite_1234567890)
  apartmentId  String   // e.g. meridian-suite
  checkIn      DateTime @db.Date
  checkOut     DateTime @db.Date
  nights       Int      // number of nights
  amountPaid    Int      // total paid in NGN (not kobo)
  currency     String   @default("NGN")
  status       BookingStatus @default(PENDING)
  expiresAt    DateTime?     // PENDING checkout holds; null once PAID/CANCELLED

  source       BookingSource @default(WEBSITE)

  // Booker details (from Paystack / form)
  bookerEmail  String?
  bookerName   String?
  bookerPhone  String?

  // Manual/offline payment metadata (for admin-created bookings)
  manualPaymentMethod    String?
  manualPaymentReference String?

  // Downstream artifacts
  invoiceId     String?
  invoicePdfPath String?

  // Optional: Link to Supabase Auth user (set when user verifies email)
  userId       String?  // Supabase auth.users.id

  // Paystack refund state for date-conflict / overlap cancellations
  refundStatus            BookingRefundStatus @default(NONE)
  paystackRefundReference String?
  refundedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs BookingJob[]

  @@index([reference])
  @@index([apartmentId])
  @@index([bookerEmail])
  @@index([bookerName])
  @@index([bookerPhone])
  @@index([invoiceId])
  @@index([userId])
  @@index([checkIn, checkOut])
  // Overlap queries: WHERE status IN (...) AND checkIn < ? AND checkOut > ?
  @@index([status, checkIn, checkOut])
  @@index([status, expiresAt])
}

enum BookingStatus {
  PENDING   // payment initiated, not yet confirmed
  PAID      // Paystack charge successful
  CANCELLED
}

enum BookingRefundStatus {
  NONE
  PENDING
  REFUNDED
  FAILED
}

enum BookingSource {
  WEBSITE
  MANUAL
}

model BookingJob {
  id        String @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type      BookingJobType
  status    BookingJobStatus @default(PENDING)
  attempts  Int @default(0)
  lastError String?
  nextRunAt DateTime?
  adminAlertSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookingId, type])
  @@index([status, nextRunAt])
  @@index([bookingId])
}

enum BookingJobType {
  INVOICE_PDF
  GUEST_BOOKING_EMAIL
  GOOGLE_SHEETS
}

enum BookingJobStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

model AdminUser {
  id             String @id @default(cuid())
  supabaseUserId String @unique
  email          String @unique
  role           AdminRole
  createdAt      DateTime @default(now())

  @@index([role])
}

enum AdminRole {
  admin
  receptionist
}

// --- Apartment images (production uploads via Supabase Storage) ---

model ApartmentImage {
  id           String   @id @default(cuid())
  apartmentId  String
  originalUrl  String
  thumbnailUrl String
  mediumUrl    String
  largeUrl     String
  blurDataUrl  String?
  altText      String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([apartmentId, displayOrder])
}

// --- Apartment tour video (one optimized tour per listing) ---

model ApartmentVideo {
  id             String   @id @default(cuid())
  apartmentId    String   @unique
  mobileMp4Url   String
  desktopMp4Url  String
  posterUrl      String
  storageKeyBase String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([apartmentId])
}

// --- Shared property amenities (pool, gym, bar, outdoor — separate from unit photos) ---

model PropertyAmenity {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  shortDescription String
  description      String?  @db.Text
  displayOrder     Int      @default(0)
  isPublished      Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  images           PropertyAmenityImage[]

  @@index([isPublished, displayOrder])
}

model PropertyAmenityImage {
  id           String   @id @default(cuid())
  amenityId    String
  amenity      PropertyAmenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  thumbnailUrl String
  mediumUrl    String
  largeUrl     String
  blurDataUrl  String?
  altText      String?
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([amenityId, displayOrder])
}

// --- Marketing page image slots (map amenity gallery photos to fixed page sections) ---

model SiteImageSlot {
  key          String   @id
  label        String
  pagePath     String
  sectionLabel String
  amenitySlug  String
  imageIndex   Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// --- Homepage hero video (optimized variants in Supabase Storage) ---

model HeroVideo {
  id             String   @id @default(cuid())
  mobileMp4Url   String
  desktopMp4Url  String
  posterUrl      String
  storageKeyBase   String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([isActive])
}

// --- Contact messages (public contact form submissions) ---
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  category  String
  message   String

  // Basic abuse triage (optional)
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([category])
}

// --- Shared rate-limit counters (serverless-safe; all instances read/write Postgres) ---
model RateLimitBucket {
  bucketKey   String   @id @map("bucket_key")
  count       Int      @default(1)
  windowStart DateTime @map("window_start")
  expiresAt   DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("rate_limit_buckets")
}
