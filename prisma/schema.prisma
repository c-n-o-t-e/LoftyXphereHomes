// Prisma schema for LoftyXphereHomes
// Database: Supabase (PostgreSQL). Set DATABASE_URL in .env to your Supabase connection string.

generator client {
  provider = "prisma-client"
  output = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- Booking (created when Paystack payment succeeds) ---

model Booking {
  id           String   @id @default(cuid())
  reference    String   @unique // Paystack transaction reference (e.g. lxh_lofty-wuye-01_1234567890)
  apartmentId  String   // e.g. lofty-wuye-01
  checkIn      DateTime @db.Date
  checkOut     DateTime @db.Date
  nights       Int      // number of nights
  amountPaid    Int      // total paid in NGN (not kobo)
  currency     String   @default("NGN")
  status       BookingStatus @default(PENDING)

  source       BookingSource @default(WEBSITE)

  // Booker details (from Paystack / form)
  bookerEmail  String?
  bookerName   String?
  bookerPhone  String?

  // Manual/offline payment metadata (for admin-created bookings)
  manualPaymentMethod    String?
  manualPaymentReference String?

  // Downstream artifacts
  invoiceId     String?
  invoicePdfPath String?

  // Optional: Link to Supabase Auth user (set when user verifies email)
  userId       String?  // Supabase auth.users.id

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs BookingJob[]

  @@index([reference])
  @@index([apartmentId])
  @@index([bookerEmail])
  @@index([bookerName])
  @@index([bookerPhone])
  @@index([invoiceId])
  @@index([userId])
  @@index([checkIn, checkOut])
  // Overlap queries: WHERE status IN (...) AND checkIn < ? AND checkOut > ?
  @@index([status, checkIn, checkOut])
}

enum BookingStatus {
  PENDING   // payment initiated, not yet confirmed
  PAID      // Paystack charge successful
  CANCELLED
}

enum BookingSource {
  WEBSITE
  MANUAL
}

model BookingJob {
  id        String @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type      BookingJobType
  status    BookingJobStatus @default(PENDING)
  attempts  Int @default(0)
  lastError String?
  nextRunAt DateTime?
  adminAlertSentAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bookingId, type])
  @@index([status, nextRunAt])
  @@index([bookingId])
}

enum BookingJobType {
  INVOICE_PDF
  GOOGLE_SHEETS
}

enum BookingJobStatus {
  PENDING
  SUCCESS
  FAILED
}

model AdminUser {
  id             String @id @default(cuid())
  supabaseUserId String @unique
  email          String @unique
  role           AdminRole
  createdAt      DateTime @default(now())

  @@index([role])
}

enum AdminRole {
  admin
  receptionist
}

// --- Contact messages (public contact form submissions) ---
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  category  String
  message   String

  // Basic abuse triage (optional)
  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([email])
  @@index([category])
}
